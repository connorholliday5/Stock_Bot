# ============================================================
# STOCK BOT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- ALPACA (Paper Trading to start) ---
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# --- POLYGON.IO (Market Data) ---
POLYGON_API_KEY=your_polygon_api_key_here

# --- BINANCE (Crypto via CCXT) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# --- DATABASE ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockbot
DB_USER=stockbot_user
DB_PASSWORD=your_db_password_here

# --- TELEGRAM ALERTS ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- BOT SETTINGS ---
ENVIRONMENT=paper
STARTING_CAPITAL=1000
MAX_STOCK_POSITIONS=8
MAX_CRYPTO_POSITIONS=3
STOCK_RISK_PER_TRADE=0.02
CRYPTO_RISK_PER_TRADE=0.015
WEEKLY_DRAWDOWN_HALT_STOCK=-0.08
WEEKLY_DRAWDOWN_HALT_CRYPTO=-0.10
MIN_POSITION_SIZE=50
