# ============================================================
# STOCK BOT .gitignore
# ============================================================

# Environment & Secrets — NEVER commit these
.env
*.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual Environment
venv/
env/
.venv/
ENV/

# Logs
logs/
*.log

# Database
*.db
*.sqlite3

# ML Models
ml/models/
*.pkl
*.joblib
*.h5

# OS
.DS_Store
Thumbs.db

# VS Code
.vscode/
*.code-workspace

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Docker
.dockerignore

# Test cache
.pytest_cache/
.coverage
htmlcov/
